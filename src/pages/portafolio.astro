---
import Layout from "../layouts/Layout.astro";

const projects = [
	{
		id: "restaurante",
		title: "La Bohemia | Restaurante & Eventos",
		thumbnail: "/img/portafolio/restaurante.webp",
		fullImage: "/img/portafolio/restaurante_full.png",
		url: "https://restaurante-eventos.vercel.app/",
		summary: "Un sitio web inmersivo y visualmente impactante para un restaurante enfocado en experiencias musicales y eventos exclusivos, inspirado en clubes de clase mundial.",
		objective: "Diseñado para cautivar a entusiastas de la música electrónica y la alta gastronomía, facilitando la reserva de mesas, promoción de eventos con DJs internacionales y visualización del menú en un formato moderno y oscuro.",
		tags: ["Entretenimiento", "Gastronomía", "Inmersivo"]
	},
	{
		id: "inmobiliaria",
		title: "Dharsain Inmobiliaria",
		thumbnail: "/img/portafolio/inmobiliaria.webp",
		fullImage: "/img/portafolio/inmobiliaria_full.png",
		url: "https://desarrolladora-inmobiliaria.vercel.app/",
		summary: "Página corporativa profesional orientada a la generación de prospectos (leads) interesados en lotes, terrenos y proyectos inmobiliarios residenciales.",
		objective: "Desarrollada para mostrar credibilidad y confianza, presentando opciones de vivienda, planes de inversión, y un ecosistema claro de servicios que guían al usuario hacia el contacto comercial.",
		tags: ["Corporativo", "Ventas", "Bienes Raíces"]
	},
	{
		id: "metalmecanica",
		title: "H&H Diseño, Fabricación y Montaje",
		thumbnail: "/img/portafolio/metalmecanica.webp",
		fullImage: "/img/portafolio/metalmecanica_full.png",
		url: "https://hh-metalmecanica.vercel.app/",
		summary: "Un sitio web B2B robusto que destaca la experiencia en diseño de ingeniería, fabricación de estructuras metálicas y montaje industrial.",
		objective: "Su propósito es captar la atención de grandes empresas y contratistas, exhibiendo la capacidad técnica, proyectos de gran envergadura y calidad en trabajos industriales, incitando a la cotización de proyectos.",
		tags: ["B2B", "Industrial", "Ingeniería"]
	},
	{
		id: "io-group",
		title: "IO Group | Gestión de Residuos",
		thumbnail: "/img/portafolio/io_group.webp",
		fullImage: "/img/portafolio/io_group_full.png",
		url: "https://portafolio-aplicacion-web.vercel.app/",
		summary: "Plataforma corporativa enfocada en la gestión especializada e integral de residuos peligrosos e industriales.",
		objective: "Construida para demostrar cumplimiento normativo y experiencia ambiental, ofreciendo a las industrias una solución clara para la recolección, tratamiento y disposición final de sus residuos, con un llamado a la acción directo.",
		tags: ["Ambiental", "Servicios B2B", "Corporativo"]
	},
	{
		id: "gasfitero",
		title: "Gasfitero en Juliaca 24/7",
		thumbnail: "/img/portafolio/gasfitero.webp",
		fullImage: "/img/portafolio/gasfitero_full.png",
		url: "https://gasfitero-en-juliaca.vercel.app/",
		summary: "Landing page de alta conversión para servicios de emergencia, diseñada para respuesta inmediata en reparaciones de fontanería local.",
		objective: "Optimizada rigurosamente para cargar rápido en dispositivos móviles y conseguir el toque instantáneo al botón de WhatsApp o llamada telefónica, solucionando la necesidad urgente del usuario.",
		tags: ["Landing Page", "Servicios Locales", "Conversión"]
	}
];
---

<Layout title="Nuestro Portafolio | SFO Estudio Web" description="Descubre los proyectos exitosos desarrollados por SFO Estudio Web.">
	
	<!-- Header / Hero Section -->
	<header class="relative pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden bg-slate-900 px-4 sm:px-6 lg:px-8">
		<div class="absolute inset-0 z-0">
			<div class="absolute inset-0 bg-gradient-to-br from-blue-900/40 to-slate-900/90 z-10"></div>
			<!-- Contenedor para una imagen de fondo sutil o patrón -->
			<div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop')] bg-cover bg-center opacity-20 filter grayscale"></div>
		</div>
		<div class="relative z-10 max-w-7xl mx-auto text-center">
			<div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-500/10 border border-blue-400/20 text-blue-300 font-medium text-sm mb-6 backdrop-blur-sm">
				<span class="flex w-2 h-2 rounded-full bg-blue-400 mr-2 animate-pulse"></span>
				Casos de Éxito
			</div>
			<h1 class="text-4xl md:text-5xl lg:text-7xl font-sans font-extrabold text-white tracking-tight mb-8">
				Nuestro Portafolio de <br class="hidden md:block" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-300">
					Proyectos Web
				</span>
			</h1>
			<p class="mt-4 max-w-2xl mx-auto text-xl text-slate-300 font-light">
				Explora cómo hemos ayudado a empresas locales e industriales a revolucionar su presencia digital, generar más ventas y destacar en internet.
			</p>
		</div>
		<!-- Wave Separator -->
		<div class="absolute bottom-0 left-0 right-0 transform translate-y-1">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320" class="w-full h-auto text-slate-50 fill-current">
				<path d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,165.3C960,192,1056,224,1152,224C1248,224,1344,192,1392,176L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
			</svg>
		</div>
	</header>

	<!-- Projects Section -->
	<section class="py-20 bg-slate-50 relative z-10">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
				{projects.map((project) => (
					<div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 group cursor-pointer border border-slate-100 flex flex-col h-full" onclick={`openProjectModal('${project.id}')`}>
						<!-- Thumbnail Wrapper -->
						<div class="relative h-64 overflow-hidden bg-slate-200">
							<div class="absolute inset-0 bg-slate-900/20 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
							<img 
								src={project.thumbnail} 
								alt={`Screenshot de ${project.title}`} 
								class="w-full h-full object-cover object-top filter brightness-95 group-hover:scale-105 transition-transform duration-700 ease-out"
								loading="lazy"
							/>
							<div class="absolute top-4 right-4 z-20">
								<span class="bg-white/90 backdrop-blur text-slate-800 text-xs font-bold px-3 py-1.5 rounded-full shadow-sm">
									Ver Proyecto
								</span>
							</div>
						</div>
						
						<!-- Card Body -->
						<div class="p-8 flex flex-col flex-1">
							<div class="flex flex-wrap gap-2 mb-4">
								{project.tags.map(tag => (
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
										{tag}
									</span>
								))}
							</div>
							<h3 class="text-2xl font-bold text-slate-900 font-sans mb-3 group-hover:text-blue-600 transition-colors">
								{project.title}
							</h3>
							<p class="text-slate-500 text-sm leading-relaxed mb-6 flex-1 line-clamp-3">
								{project.summary}
							</p>
							
							<button class="w-full mt-auto inline-flex items-center justify-center px-5 py-3 border border-slate-200 text-base font-medium rounded-xl text-slate-700 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all">
								Conocer más detalles
								<svg class="ml-2 -mr-1 w-5 h-5 text-slate-400 group-hover:text-blue-500 transform group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
							</button>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Call to Action -->
	<section class="py-24 bg-white">
		<div class="max-w-4xl mx-auto px-4 text-center">
			<h2 class="text-3xl md:text-5xl font-bold text-slate-900 font-sans mb-6">¿Listo para ser nuestro próximo caso de éxito?</h2>
			<p class="text-lg text-slate-500 mb-10 max-w-2xl mx-auto">Construimos páginas web que no solo se ven increíbles, sino que están optimizadas para traer clientes reales a tu negocio.</p>
			<a href="#" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-blue-600 hover:bg-blue-700 shadow-lg hover:shadow-blue-500/30 transition-all hover:-translate-y-1">
				Contactar Ahora
				<svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
			</a>
		</div>
	</section>

	<!-- Footer Minimal -->
	<footer class="bg-slate-900 border-t border-slate-800 py-12">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
			<img src="/img/logo_sfo.png" alt="SFO Logo" class="h-10 opacity-50 grayscale mb-6" />
			<p class="text-slate-500 text-sm">
				&copy; {new Date().getFullYear()} SFO Estudio Web. Todos los derechos reservados.
			</p>
		</div>
	</footer>

	<!-- Modals Data Container -->
	<div id="projects-data" class="hidden">
		{JSON.stringify(projects)}
	</div>

	<!-- Custom Modal Dialog (Cartilla) -->
	<dialog id="project-modal" class="bg-transparent m-auto p-0 w-full max-w-6xl backdrop:bg-slate-900/80 backdrop:backdrop-blur-sm open:animate-in open:fade-in open:zoom-in-95 duration-300">
		<div class="bg-white rounded-2xl md:rounded-[2rem] shadow-2xl w-full max-h-[90vh] overflow-hidden flex flex-col md:flex-row relative">
			
			<!-- Close Button -->
			<button id="close-modal-btn" class="absolute top-4 right-4 md:top-6 md:right-6 z-50 bg-white/50 md:bg-white hover:bg-slate-100 text-slate-600 p-2.5 rounded-full backdrop-blur-md shadow-sm transition-transform hover:scale-110" aria-label="Cerrar modal">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
			</button>

			<!-- Left Side: Interactive Screenshot Preview -->
			<div class="w-full md:w-1/2 lg:w-3/5 bg-slate-100 border-r border-slate-200 h-64 md:h-[90vh] overflow-y-auto custom-scrollbar relative group relative">
				<!-- Header visual -->
				<div class="sticky top-0 bg-white/80 backdrop-blur-md border-b border-slate-200 py-3 px-4 flex items-center space-x-2 z-20">
					<div class="flex space-x-1.5">
						<div class="w-3 h-3 rounded-full bg-red-400"></div>
						<div class="w-3 h-3 rounded-full bg-amber-400"></div>
						<div class="w-3 h-3 rounded-full bg-green-400"></div>
					</div>
					<div class="flex-1 text-center">
						<div class="bg-slate-100 text-slate-500 text-xs py-1 px-3 rounded-md inline-block font-mono bg-white shadow-sm" id="modal-browser-url">
							https://example.com
						</div>
					</div>
				</div>
				<!-- Full screenshot -->
				<img id="modal-project-img" src="" alt="Vista completa del proyecto" class="w-full h-auto object-cover transform origin-top transition-transform duration-500" />
				
				<!-- Scroll hint for visual cue -->
				<div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 bg-slate-900/60 backdrop-blur-md text-white px-4 py-2 rounded-full text-sm font-medium flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none shadow-lg">
					<svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
					Desliza para ver más
				</div>
			</div>

			<!-- Right Side: Content & Cartilla -->
			<div class="w-full md:w-1/2 lg:w-2/5 p-8 md:p-12 h-auto md:h-[90vh] overflow-y-auto flex flex-col bg-white">
				<div class="mt-4 md:mt-10">
					<div id="modal-project-tags" class="flex flex-wrap gap-2 mb-4">
						<!-- Tags injected by JS -->
					</div>
					
					<h2 id="modal-project-title" class="text-3xl md:text-4xl font-extrabold text-slate-900 font-sans mb-6 leading-tight">
						<!-- Title injected here -->
					</h2>
					
					<div class="space-y-8">
						<div>
							<h3 class="flex items-center text-sm font-bold text-slate-400 uppercase tracking-wider mb-3">
								<svg class="w-5 h-5 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
								Resumen del Proyecto
							</h3>
							<p id="modal-project-summary" class="text-slate-600 text-lg leading-relaxed">
								<!-- Summary injected here -->
							</p>
						</div>

						<div class="p-6 bg-blue-50/50 rounded-2xl border border-blue-100/50">
							<h3 class="flex items-center text-sm font-bold text-blue-800 uppercase tracking-wider mb-3">
								<svg class="w-5 h-5 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
								¿Para qué se hizo?
							</h3>
							<p id="modal-project-objective" class="text-slate-700 leading-relaxed">
								<!-- Objective injected here -->
							</p>
						</div>
					</div>
				</div>

				<!-- Fixed Bottom Action -->
				<div class="mt-auto pt-10 pb-4">
					<a id="modal-project-url" href="#" target="_blank" rel="noopener noreferrer" class="group flex items-center justify-center w-full px-6 py-4 text-lg font-bold rounded-xl text-white bg-slate-900 hover:bg-black shadow-xl hover:shadow-2xl transition-all hover:-translate-y-1">
						Visitar Sitio Web Oficial
						<svg class="ml-2 w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
					</a>
					<p class="text-center text-xs text-slate-400 mt-4">El sitio se abrirá en una nueva pestaña</p>
				</div>
			</div>
		</div>
	</dialog>

	<style>
		/* Custom scrollbar for the modal screenshot area */
		.custom-scrollbar::-webkit-scrollbar {
			width: 8px;
		}
		.custom-scrollbar::-webkit-scrollbar-track {
			background: #f1f5f9; 
		}
		.custom-scrollbar::-webkit-scrollbar-thumb {
			background: #cbd5e1; 
			border-radius: 4px;
		}
		.custom-scrollbar::-webkit-scrollbar-thumb:hover {
			background: #94a3b8; 
		}
		
		/* Remove default dialog backdrop to use Tailwind's */
		dialog::backdrop {
			background: transparent;
		}
	</style>

	<script>
		// Setup interactions
		document.addEventListener('DOMContentLoaded', () => {
			const projectsDataEl = document.getElementById('projects-data');
			const modal = document.getElementById('project-modal') as HTMLDialogElement;
			const closeBtn = document.getElementById('close-modal-btn');
			
			if (!projectsDataEl || !modal || !closeBtn) return;
			
			const projects = JSON.parse(projectsDataEl.textContent || '[]');
			
			// Global function to open modal
			(window as any).openProjectModal = (projectId: string) => {
				const project = projects.find((p: any) => p.id === projectId);
				if (!project) return;
				
				// Populate modal elements
				const titleEl = document.getElementById('modal-project-title');
				const summaryEl = document.getElementById('modal-project-summary');
				const objectiveEl = document.getElementById('modal-project-objective');
				const imgEl = document.getElementById('modal-project-img') as HTMLImageElement;
				const urlEl = document.getElementById('modal-project-url') as HTMLAnchorElement;
				const browserUrlEl = document.getElementById('modal-browser-url');
				const tagsContainer = document.getElementById('modal-project-tags');
				
				if (titleEl) titleEl.textContent = project.title;
				if (summaryEl) summaryEl.textContent = project.summary;
				if (objectiveEl) objectiveEl.textContent = project.objective;
				if (urlEl) urlEl.href = project.url;
				
				if (browserUrlEl) {
					try {
						const urlObj = new URL(project.url);
						browserUrlEl.textContent = urlObj.hostname;
					} catch(e) {
						browserUrlEl.textContent = project.url;
					}
				}
				
				if (imgEl) {
					imgEl.src = project.fullImage;
					imgEl.alt = `Vista completa de ${project.title}`;
				}
				
				if (tagsContainer) {
					tagsContainer.innerHTML = project.tags.map((tag: string) => 
						`<span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium bg-slate-100 text-slate-700 border border-slate-200">${tag}</span>`
					).join('');
				}
				
				// Show modal
				modal.showModal();
				document.body.style.overflow = 'hidden'; // Prevent background scrolling
			};
			
			// Close modal on click of close button
			closeBtn.addEventListener('click', () => {
				modal.close();
				document.body.style.overflow = '';
			});
			
			// Close modal on click outside (on backdrop)
			modal.addEventListener('click', (e) => {
				const dialogDimensions = modal.getBoundingClientRect()
				if (
					e.clientX < dialogDimensions.left ||
					e.clientX > dialogDimensions.right ||
					e.clientY < dialogDimensions.top ||
					e.clientY > dialogDimensions.bottom
				) {
					modal.close();
					document.body.style.overflow = '';
				}
			});
		});
	</script>
</Layout>
