---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Gestión de Facturas">
    <!-- UI ESTADO: CARGANDO -->
    <div id="ui-loading" class="fixed inset-0 bg-slate-900/40 backdrop-blur-md flex items-center justify-center z-50 transition-opacity duration-300">
        <div class="bg-white/80 p-6 rounded-2xl shadow-xl flex flex-col items-center space-y-4">
            <div class="w-10 h-10 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
            <p class="text-slate-700 font-medium">Autenticando...</p>
        </div>
    </div>

    <!-- UI ESTADO: LOGIN -->
    <div id="ui-login" class="hidden min-h-screen flex items-center justify-center bg-[url('/img/portada.jpg')] bg-cover bg-center relative">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
        <div class="relative z-10 w-full max-w-md bg-white/10 backdrop-blur-xl border border-white/20 p-8 rounded-3xl shadow-2xl overflow-hidden">
            <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-blue-500 via-purple-500 to-blue-500"></div>
            <div class="text-center">
                <img src="/img/logo_sfo.png" alt="SFO Estudio Web" class="h-16 mx-auto mb-6 brightness-0 invert drop-shadow-md" />
                <h1 class="text-3xl font-bold text-white mb-2 font-['Outfit']">Acceso Restringido</h1>
                <p class="text-white/80 mb-8 text-sm">Panel administrativo exclusivo.</p>
                <button id="btn-login" class="w-full bg-white text-slate-900 font-semibold py-3.5 px-4 rounded-xl shadow-lg hover:bg-slate-50 transition-all hover:scale-[1.02] active:scale-95 flex items-center justify-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path></svg>
                    <span>Iniciar Sesión Segura</span>
                </button>
            </div>
        </div>
    </div>

    <!-- UI ESTADO: DASHBOARD -->
    <div id="ui-dashboard" class="hidden min-h-screen bg-slate-50 flex flex-col">
        <!-- Top Navigation -->
        <nav class="bg-white border-b border-slate-200 sticky top-0 z-30 shadow-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16">
                    <div class="flex items-center space-x-4">
                        <img src="/img/logo_sfo.png" alt="SFO Logo" class="h-8 w-auto filter drop-shadow" />
                        <span class="font-['Outfit'] font-bold text-xl text-slate-800 tracking-tight">Admin<span class="text-blue-600">Panel</span></span>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="flex flex-col text-right hidden sm:block">
                            <span id="user-name" class="text-sm font-semibold text-slate-700 block">Cargando...</span>
                            <span id="user-email" class="text-xs text-slate-500 block">...</span>
                        </div>
                        <img id="user-picture" src="" alt="Avatar" class="h-9 w-9 rounded-full ring-2 ring-blue-100 hidden sm:block cursor-pointer hover:ring-blue-300 transition-all object-cover" />
                        <button id="btn-logout" class="ml-4 text-slate-500 hover:text-red-600 transition-colors p-2 rounded-lg hover:bg-red-50" title="Cerrar Sesión">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                        </button>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Tab Navigation -->
        <div class="bg-white border-b border-slate-200 shadow-sm">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex space-x-1 -mb-px" aria-label="Tabs">
                    <a href="/admin" class="px-4 py-3 text-sm font-medium text-slate-500 hover:text-slate-700 hover:border-slate-300 border-b-2 border-transparent transition-colors">Clientes</a>
                    <a href="/admin/catalogo" class="px-4 py-3 text-sm font-medium text-slate-500 hover:text-slate-700 hover:border-slate-300 border-b-2 border-transparent transition-colors">Catálogo Servicios</a>
                    <a href="/admin/facturas" class="px-4 py-3 text-sm font-medium text-blue-600 border-b-2 border-blue-600 transition-colors">Facturas</a>
                </nav>
            </div>
        </div>

        <!-- Main Content -->
        <main class="flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-slate-900 font-['Outfit']">Facturas / Proformas</h2>
                    <p class="text-slate-500 text-sm mt-1">Gestiona las facturas emitidas a empresas de tus clientes.</p>
                </div>
                <button id="btn-new-invoice" class="bg-emerald-600 hover:bg-emerald-700 text-white px-5 py-2.5 rounded-xl font-medium shadow-sm shadow-emerald-200 hover:shadow-md hover:-translate-y-0.5 transition-all flex items-center space-x-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                    <span>Nueva Factura</span>
                </button>
            </div>

            <!-- Table Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200">
                        <thead class="bg-slate-50">
                            <tr>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Factura</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Empresa</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Servicio</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Monto</th>
                                <th scope="col" class="px-6 py-4 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                                <th scope="col" class="px-6 py-4 text-right text-xs font-semibold text-slate-500 uppercase tracking-wider">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="invoices-tbody" class="bg-white divide-y divide-slate-100">
                        </tbody>
                    </table>
                </div>
                <div id="empty-state-invoices" class="hidden flex flex-col items-center justify-center p-12 text-center">
                    <div class="bg-emerald-50 p-4 rounded-full mb-4">
                        <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    </div>
                    <h3 class="text-lg font-medium text-slate-900">No hay facturas aún</h3>
                    <p class="mt-1 text-sm text-slate-500">Crea tu primera factura para un cliente.</p>
                </div>
            </div>
        </main>
    </div>

    <!-- MODAL FACTURA (Crear / Editar) -->
    <dialog id="modal-invoice" class="bg-transparent p-0 m-auto w-full max-w-lg backdrop:bg-slate-900/50 backdrop:backdrop-blur-sm open:animate-in open:fade-in open:zoom-in-95">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden w-full m-4">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                <h3 class="text-lg font-bold text-slate-900 font-['Outfit']" id="modal-title-invoice">Nueva Factura</h3>
                <button type="button" id="btn-close-modal-invoice" class="text-slate-400 hover:text-slate-700 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form id="form-invoice" class="p-6 space-y-4">
                <input type="hidden" id="invoice-id" name="id" />
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Empresa <span class="text-red-500">*</span></label>
                    <select id="invoice-empresa" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm outline-none cursor-pointer">
                        <option value="" disabled selected>Seleccione una empresa...</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Tipo de Servicio <span class="text-red-500">*</span></label>
                    <select id="invoice-servicio" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm outline-none cursor-pointer">
                        <option value="" disabled selected>Seleccione un servicio...</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Monto (S/) <span class="text-red-500">*</span></label>
                        <input type="number" id="invoice-monto" required min="0" step="0.01" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm outline-none" placeholder="0.00" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Descuento (S/)</label>
                        <input type="number" id="invoice-descuento" min="0" step="0.01" value="0" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm outline-none" placeholder="0.00" />
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Estado</label>
                    <select id="invoice-estado" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm outline-none cursor-pointer">
                        <option value="pendiente">Pendiente</option>
                        <option value="pagado">Pagado</option>
                        <option value="anulado">Anulado</option>
                    </select>
                </div>
                <div class="pt-4 flex justify-end space-x-3">
                    <button type="button" id="btn-cancel-modal-invoice" class="px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">Cancelar</button>
                    <button type="submit" id="btn-save-invoice" class="px-5 py-2 text-sm font-medium text-white bg-emerald-600 hover:bg-emerald-700 rounded-lg shadow-sm transition-colors flex items-center space-x-2">
                        <span>Guardar Factura</span>
                    </button>
                </div>
            </form>
        </div>
    </dialog>

    <script>
        import { getAuth0Client } from "../../lib/authClient";
        import { getSupabaseClient } from "../../lib/supabaseClient";

        const uiLoading = document.getElementById("ui-loading");
        const uiLogin = document.getElementById("ui-login");
        const uiDashboard = document.getElementById("ui-dashboard");
        const btnLogin = document.getElementById("btn-login");
        const btnLogout = document.getElementById("btn-logout");
        const userName = document.getElementById("user-name");
        const userEmail = document.getElementById("user-email");
        const userPicture = document.getElementById("user-picture") as HTMLImageElement;

        const invoicesTbody = document.getElementById("invoices-tbody");
        const emptyStateInvoices = document.getElementById("empty-state-invoices");
        const btnNewInvoice = document.getElementById("btn-new-invoice");
        const modalInvoice = document.getElementById("modal-invoice") as HTMLDialogElement;
        const formInvoice = document.getElementById("form-invoice") as HTMLFormElement;
        const btnCloseModalInvoice = document.getElementById("btn-close-modal-invoice");
        const btnCancelModalInvoice = document.getElementById("btn-cancel-modal-invoice");
        const modalTitleInvoice = document.getElementById("modal-title-invoice");

        let auth0: any = null;
        let supabase: any = null;

        const initAuth = async () => {
            try {
                auth0 = await getAuth0Client();
                if (!auth0) throw new Error("Missing Auth0 configuration.");

                if (window.location.search.includes("code=") && window.location.search.includes("state=")) {
                    await auth0.handleRedirectCallback();
                    window.history.replaceState({}, document.title, "/admin/facturas");
                }

                const isAuthenticated = await auth0.isAuthenticated();
                if (isAuthenticated) {
                    const user = await auth0.getUser();
                    if (userName) userName.textContent = user?.name || "Admin";
                    if (userEmail) userEmail.textContent = user?.email || "";
                    if (userPicture && user?.picture) { userPicture.src = user.picture; userPicture.classList.remove("hidden"); }

                    uiLogin?.classList.add("hidden");
                    uiDashboard?.classList.remove("hidden");
                    supabase = getSupabaseClient();
                    if (supabase) await loadInvoices();
                } else {
                    uiDashboard?.classList.add("hidden");
                    uiLogin?.classList.remove("hidden");
                }
            } catch (error) {
                console.error("Auth error:", error);
                uiDashboard?.classList.add("hidden");
                uiLogin?.classList.remove("hidden");
            } finally {
                uiLoading?.classList.add("hidden");
            }
        };

        const loadInvoices = async () => {
            try {
                const { data, error } = await supabase
                    .from("factura")
                    .select("*, empresas(razon_social, numero_ruc), tipo_servicio(nombre_servicio)")
                    .order("created_at", { ascending: false });
                if (error) throw error;
                renderInvoices(data || []);
            } catch (err) {
                console.error("Error loading invoices:", err);
            }
        };

        const renderInvoices = (invoices: any[]) => {
            if (!invoicesTbody || !emptyStateInvoices) return;
            invoicesTbody.innerHTML = "";

            if (invoices.length === 0) {
                emptyStateInvoices.classList.remove("hidden");
                return;
            }
            emptyStateInvoices.classList.add("hidden");

            invoices.forEach((inv: any) => {
                const tr = document.createElement("tr");
                tr.className = "hover:bg-slate-50 transition-colors group";

                const estadoColors: Record<string, string> = {
                    pendiente: "bg-amber-100 text-amber-800",
                    pagado: "bg-emerald-100 text-emerald-800",
                    anulado: "bg-red-100 text-red-800",
                };
                const estadoColor = estadoColors[inv.estado] || "bg-slate-100 text-slate-800";
                const fecha = new Date(inv.created_at).toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" });
                const montoTotal = (parseFloat(inv.monto) - parseFloat(inv.descuento || 0)).toFixed(2);

                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-mono font-semibold text-slate-900">#${inv.id_factura.substring(0, 8).toUpperCase()}</div>
                        <div class="text-xs text-slate-500">${fecha}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-semibold text-slate-900">${inv.empresas?.razon_social || 'N/A'}</div>
                        <div class="text-xs text-slate-500">${inv.empresas?.numero_ruc || ''}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-slate-700">${inv.tipo_servicio?.nombre_servicio || 'N/A'}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-bold text-slate-900">S/ ${montoTotal}</div>
                        ${parseFloat(inv.descuento || 0) > 0 ? `<div class="text-xs text-red-500">-S/ ${parseFloat(inv.descuento).toFixed(2)} desc.</div>` : ''}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full ${estadoColor} capitalize">${inv.estado}</span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                        <div class="flex items-center justify-end space-x-2 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="window.location.href='/admin/factura?id=${inv.id_factura}'" class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors border border-blue-100" title="Imprimir">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                            </button>
                            <button onclick="window.deleteInvoice('${inv.id_factura}')" class="text-red-600 hover:text-red-900 bg-red-50 hover:bg-red-100 p-2 rounded-lg transition-colors border border-red-100" title="Eliminar">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                            </button>
                        </div>
                    </td>
                `;
                invoicesTbody.appendChild(tr);
            });
        };

        const loadFormSelects = async () => {
            // Load empresas
            const selEmpresa = document.getElementById("invoice-empresa") as HTMLSelectElement;
            const { data: empresas } = await supabase.from("empresas").select("id_empresa, razon_social, numero_ruc").order("razon_social");
            selEmpresa.innerHTML = '<option value="" disabled selected>Seleccione una empresa...</option>';
            empresas?.forEach((e: any) => {
                const opt = document.createElement("option");
                opt.value = e.id_empresa;
                opt.textContent = `${e.razon_social} (${e.numero_ruc})`;
                selEmpresa.appendChild(opt);
            });

            // Load tipo_servicio (for invoices FK)
            const selServicio = document.getElementById("invoice-servicio") as HTMLSelectElement;
            const { data: servicios } = await supabase.from("tipo_servicio").select("id_servicio, nombre_servicio, costo_servicio").order("nombre_servicio");
            selServicio.innerHTML = '<option value="" disabled selected>Seleccione un servicio...</option>';
            servicios?.forEach((s: any) => {
                const opt = document.createElement("option");
                opt.value = s.id_servicio;
                opt.textContent = `${s.nombre_servicio} (S/ ${parseFloat(s.costo_servicio).toFixed(2)})`;
                selServicio.appendChild(opt);
            });
        };

        // Modal logic
        const closeInvoiceModal = () => { modalInvoice?.close(); formInvoice?.reset(); };
        btnCloseModalInvoice?.addEventListener("click", closeInvoiceModal);
        btnCancelModalInvoice?.addEventListener("click", closeInvoiceModal);

        btnNewInvoice?.addEventListener("click", async () => {
            if (modalTitleInvoice) modalTitleInvoice.textContent = "Nueva Factura";
            formInvoice?.reset();
            (document.getElementById("invoice-id") as HTMLInputElement).value = "";
            await loadFormSelects();
            modalInvoice?.showModal();
        });

        formInvoice?.addEventListener("submit", async (e) => {
            e.preventDefault();
            const btn = document.getElementById("btn-save-invoice") as HTMLButtonElement;
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = `<svg class="w-5 h-5 animate-spin mx-auto text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>`;

            const id = (document.getElementById("invoice-id") as HTMLInputElement).value;
            const monto = parseFloat((document.getElementById("invoice-monto") as HTMLInputElement).value);
            const descuento = parseFloat((document.getElementById("invoice-descuento") as HTMLInputElement).value) || 0;
            const payload = {
                id_empresa: (document.getElementById("invoice-empresa") as HTMLSelectElement).value,
                id_tipo_servicio: (document.getElementById("invoice-servicio") as HTMLSelectElement).value,
                monto,
                descuento,
                monto_total: monto - descuento,
                estado: (document.getElementById("invoice-estado") as HTMLSelectElement).value,
            };

            try {
                if (id) {
                    const { error } = await supabase.from("factura").update(payload).eq("id_factura", id);
                    if (error) throw error;
                } else {
                    const { error } = await supabase.from("factura").insert([payload]);
                    if (error) throw error;
                }
                closeInvoiceModal();
                await loadInvoices();
            } catch (err: any) {
                console.error("Error saving invoice:", err);
                alert("Error al guardar factura: " + err.message);
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        });

        (window as any).deleteInvoice = async (id: string) => {
            if (confirm("¿Eliminar esta factura permanentemente?")) {
                try {
                    const { error } = await supabase.from("factura").delete().eq("id_factura", id);
                    if (error) throw error;
                    await loadInvoices();
                } catch (err: any) {
                    console.error("Error deleting invoice:", err);
                    alert("Error al eliminar: " + err.message);
                }
            }
        };

        btnLogin?.addEventListener("click", async () => { if (auth0) await auth0.loginWithRedirect(); });
        btnLogout?.addEventListener("click", async () => { if (auth0) await auth0.logout({ logoutParams: { returnTo: window.location.origin + "/admin" } }); });

        document.addEventListener("DOMContentLoaded", () => { initAuth(); });
    </script>
</AdminLayout>
