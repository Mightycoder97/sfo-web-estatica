---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Imprimir Contrato">
    <!-- NO-PRINT Navigation Bar -->
    <div
        class="print:hidden bg-slate-800 text-white p-4 flex justify-between items-center shadow-md"
    >
        <div class="flex items-center space-x-3">
            <button
                onclick="window.history.back()"
                class="hover:bg-slate-700 p-2 rounded-lg transition-colors flex items-center space-x-1"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
                <span>Volver</span>
            </button>
            <h1 class="font-semibold">Generador de Contrato</h1>
        </div>
        <button
            onclick="window.print()"
            class="bg-blue-600 hover:bg-blue-500 px-4 py-2 rounded-lg font-medium shadow-sm transition-colors flex items-center space-x-2"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                ></path>
            </svg>
            <span>Imprimir PDF</span>
        </button>
    </div>

    <div
        id="loading"
        class="print:hidden flex flex-col items-center justify-center p-20"
    >
        <div
            class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin mb-4"
        >
        </div>
        <p class="text-slate-600">Cargando datos del cliente...</p>
    </div>

    <!-- DOCUMENT PAGE 1: CONTRATO -->
    <div
        id="document-content"
        class="hidden font-['Inter'] text-slate-800 bg-white"
    >
        <div
            class="w-full max-w-[210mm] mx-auto min-h-[297mm] bg-white p-12 print:w-[210mm] print:m-0 shadow-2xl print:shadow-none text-[10pt] leading-relaxed flex flex-col relative"
        >
            <div
                class="absolute top-0 inset-x-0 h-4 bg-gradient-to-r from-blue-600 via-sky-500 to-indigo-600"
            >
            </div>

            <div
                class="flex flex-col sm:flex-row justify-between items-center border-b-2 border-slate-200 pb-6 mb-8 mt-4"
            >
                <div
                    class="flex flex-col items-center sm:items-start text-center sm:text-left"
                >
                    <img
                        src="/img/logo_sfo.png"
                        alt="SFO Logo"
                        class="h-14 mb-2 filter drop-shadow opacity-90"
                    />
                    <h1
                        class="text-xl font-bold font-['Outfit'] uppercase tracking-wider text-slate-900"
                    >
                        SFO Estudio Web
                    </h1>
                    <p
                        class="text-blue-600 text-xs font-semibold uppercase tracking-widest mt-0.5"
                    >
                        Transformación Digital
                    </p>
                </div>
                <div class="text-right flex flex-col items-end mt-4 sm:mt-0">
                    <h3
                        class="text-2xl font-bold font-['Outfit'] uppercase text-slate-800 tracking-tight"
                    >
                        Acuerdo de Servicios
                    </h3>
                    <p class="text-slate-500 text-sm mt-1 mb-2">
                        Términos y Condiciones Legales
                    </p>
                    <span
                        class="bg-blue-50 text-blue-700 text-xs px-3 py-1 rounded-full font-medium border border-blue-100 uppercase tracking-widest block"
                        id="portada-fecha"></span>
                </div>
            </div>

            <div class="flex-grow">
                <p class="text-justify mb-4">
                    Conste por el presente documento, el CONTRATO DE PRESTACIÓN
                    DE SERVICIOS que celebran de una parte <strong
                        >SFO ESTUDIO WEB</strong
                    >, representado por su Director General <strong
                        >Sebastian Leonardo Retamozo Reategui</strong
                    >, debidamente identificado con DNI N° 75510799, a quien en
                    adelante se le denominará "EL PROVEEDOR"; y de la otra parte
                    el CLIENTE detallado a continuación:
                </p>

                <div
                    class="bg-blue-50/50 p-6 rounded border border-blue-100 mb-6 grid grid-cols-2 gap-4"
                >
                    <div class="flex flex-col">
                        <span class="text-xs uppercase font-bold text-slate-500"
                            >Nombre / Razón Social:</span
                        >
                        <span
                            id="doc-nombre"
                            class="font-semibold text-slate-900 mt-1 text-sm"
                        ></span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase font-bold text-slate-500"
                            >Identificación:</span
                        >
                        <span
                            id="doc-rut"
                            class="font-semibold text-slate-900 mt-1 text-sm"
                        ></span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase font-bold text-slate-500"
                            >Representante:</span
                        >
                        <span
                            id="doc-rep"
                            class="font-semibold text-slate-900 mt-1 text-sm"
                        ></span>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-xs uppercase font-bold text-slate-500"
                            >Correo Electrónico:</span
                        >
                        <span
                            id="doc-email"
                            class="font-semibold text-slate-900 mt-1 text-sm"
                        ></span>
                    </div>
                </div>

                <p
                    class="font-bold text-slate-800 mb-2 underline decoration-blue-200 underline-offset-4"
                >
                    CLÁUSULA PRIMERA: OBJETO DEL CONTRATO
                </p>
                <p class="text-justify mb-5 text-slate-700">
                    EL PROVEEDOR se compromete a prestar a favor de EL CLIENTE
                    los servicios de diseño y desarrollo de plataforma web,
                    incluyendo estructura y funcionalidades acordadas
                    previamente.
                </p>

                <p
                    class="font-bold text-slate-800 mb-2 underline decoration-blue-200 underline-offset-4"
                >
                    CLÁUSULA SEGUNDA: CONDICIONES COMERCIALES Y DE PAGO
                </p>
                <p class="text-justify mb-5 text-slate-700 leading-normal">
                    2.1. El costo total acordado por el servicio de desarrollo
                    web asciende a la suma de <strong
                        class="text-slate-900"
                        id="doc-precio">S/ 0.00</strong
                    >.<br />
                    2.2. OBLIGATORIAMENTE se debe abonar un
                    <strong>adelanto del 30% (S/ 100.00 nuevos soles)</strong>
                    del monto total para dar inicio formal a los trabajos de desarrollo.
                    Una vez culminado el proyecto y cancelado el saldo restante,
                    EL PROVEEDOR hará entrega inmediata de las respectivas <strong
                        >credenciales de acceso</strong
                    >.<br />
                    2.3. Modalidades de pago aceptadas: <strong
                        >Billetera virtual (Yape o Plin)</strong
                    > o por <strong
                        >Transferencia bancaria Vía BCP o Interbank</strong
                    >. Los datos exactos serán proporcionados en el comprobante
                    fiscal.
                </p>

                <p
                    class="font-bold text-slate-800 mb-2 underline decoration-blue-200 underline-offset-4"
                >
                    CLÁUSULA TERCERA: INCLUSIONES ESPECÍFICAS
                </p>
                <p class="text-justify mb-5 text-slate-700 leading-normal">
                    3.1. <strong>Dominio y Hosting</strong>: El servicio
                    ofrecido por EL PROVEEDOR incluye el registro del dominio
                    web y el servicio de alojamiento (hosting) cubierto por el
                    periodo de <strong>UN (1) AÑO</strong> a partir de su publicación.<br
                    />
                    3.2. <strong>Sesiones de Revisión</strong>: Todo proyecto
                    contará explícitamente con <strong
                        >TRES (3) rondas de revisión (sesiones)</strong
                    > programadas, en las cuales EL CLIENTE levantará todas las observaciones
                    consolidadas respecto al diseño y contenido.<br />
                    3.3. <strong>Aprobación de Diseño</strong>: EL PROVEEDOR
                    presentará un modelo o "Diseño Inicial" de la plataforma,
                    que deberá ser aprobado formalmente por EL CLIENTE antes de
                    proceder a la fase de programación (desarrollo).
                </p>

                <p
                    class="font-bold text-slate-800 mb-2 underline decoration-blue-200 underline-offset-4"
                >
                    CLÁUSULA CUARTA: CONFIDENCIALIDAD
                </p>
                <p class="text-justify mb-5 text-slate-700">
                    Ambas partes mantendrán en estricta confidencialidad toda la
                    información manejada para el desarrollo de los proyectos y
                    no podrá ser revelada a terceros sin el consentimiento
                    escrito de la contraparte.
                </p>
            </div>

            <!-- Firmas -->
            <div class="mt-8">
                <p class="mb-16">
                    Estando conforme con todas las cláusulas, firman el presente
                    documento:
                </p>

                <div class="flex justify-between mt-12 pt-8">
                    <!-- Firma SFO -->
                    <div class="text-center w-64">
                        <div class="border-t-2 border-slate-800 pt-2 relative">
                            <!-- Optional: Placeholder for actual written signature image goes here above the line -->
                            <p
                                class="font-bold text-sm text-slate-900 uppercase"
                            >
                                Sebastian Leonardo Retamozo Reategui
                            </p>
                            <p class="text-xs text-slate-600">
                                Director de SFO Estudio Web
                            </p>
                            <p class="text-xs text-slate-500">DNI: 75510799</p>
                        </div>
                    </div>

                    <!-- Firma Cliente -->
                    <div class="text-center w-64">
                        <div class="border-t-2 border-slate-800 pt-2">
                            <p
                                id="firma-cliente-nombre"
                                class="font-bold text-sm text-slate-900 uppercase min-h-[1rem]"
                            >
                            </p>
                            <p
                                id="firma-cliente-doc"
                                class="text-xs text-slate-600 min-h-[1rem]"
                            >
                            </p>
                            <p class="text-xs text-slate-500">
                                Representante Legal / Cliente
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        import { getSupabaseClient } from "../../lib/supabaseClient";

        document.addEventListener("DOMContentLoaded", async () => {
            const urlParams = new URLSearchParams(window.location.search);
            const clientId = urlParams.get("id");

            if (!clientId) {
                alert("ID de cliente no proporcionado.");
                return;
            }

            const supabase = getSupabaseClient();
            if (!supabase) return;

            try {
                // Fetch basic client
                const { data: cliente, error } = await supabase
                    .from("clientes")
                    .select(
                        `
                        *,
                        empresas(
                            *,
                            factura(
                                *,
                                tipo_servicio(*)
                            )
                        )
                    `
                    )
                    .eq("id_cliente", clientId)
                    .single();

                if (error) throw error;

                const empresa =
                    cliente.empresas && cliente.empresas.length > 0
                        ? cliente.empresas[0]
                        : null;

                const nombreCompleto = `${cliente.nombres} ${cliente.apellidos}`;
                const nombreEmpresa = empresa
                    ? empresa.razon_social
                    : nombreCompleto;
                const docEmpresa = empresa
                    ? `RUC ${empresa.numero_ruc}`
                    : `${cliente.tipo_documento} ${cliente.numero_documento}`;

                const dateOptions: Intl.DateTimeFormatOptions = {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                };
                document.getElementById("portada-fecha")!.textContent =
                    new Date().toLocaleDateString("es-ES", dateOptions);

                // Populate Document
                document.getElementById("doc-nombre")!.textContent =
                    nombreEmpresa;
                document.getElementById("doc-rut")!.textContent =
                    docEmpresa.replace(":", "");
                document.getElementById("doc-rep")!.textContent = empresa
                    ? nombreCompleto
                    : "(Mismo)";
                document.getElementById("doc-email")!.textContent =
                    cliente.email || "N/A";

                // Precios y montos desde Supabase (como en la factura)
                let montoTotal = 0.0;
                let descuento = 0.0;

                if (empresa && empresa.factura && empresa.factura.length > 0) {
                    const factura = empresa.factura[0]; // pick latest
                    montoTotal = parseFloat(factura.monto);
                    descuento = parseFloat(factura.descuento || 0);
                }
                const totalFinal = montoTotal - descuento;
                document.getElementById("doc-precio")!.textContent =
                    totalFinal > 0
                        ? `S/ ${totalFinal.toFixed(2)}`
                        : "S/ (A CUANTIFICAR)";

                // Populate Signatures
                document.getElementById("firma-cliente-nombre")!.textContent =
                    nombreCompleto;
                document.getElementById(
                    "firma-cliente-doc"
                )!.textContent = `${cliente.tipo_documento}: ${cliente.numero_documento}`;

                // Show document content, hide loader
                document.getElementById("loading")!.classList.add("hidden");
                document
                    .getElementById("document-content")!
                    .classList.remove("hidden");
            } catch (error) {
                console.error(
                    "Error loading client details for contract:",
                    error
                );
                alert("Hubo un error cargando los datos del cliente");
            }
        });
    </script>
</AdminLayout>
