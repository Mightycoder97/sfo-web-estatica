---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---
<AdminLayout title="Empresas">
	
	<div class="mb-6 flex flex-col sm:flex-row gap-4 items-center justify-between">
		<div class="relative w-full sm:w-96">
			<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
			</div>
			<input type="text" id="search-input" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full pl-10 p-2.5 shadow-sm" placeholder="Buscar por RUC, razón social o nombre comercial...">
		</div>
		<a href="/admin/empresas/nueva" class="w-full sm:w-auto flex items-center justify-center gap-2 text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/><path d="m16 4 4 4-4 4"/></svg>
			Nueva Empresa
		</a>
	</div>

	<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
		<div class="overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-gray-50 border-b border-gray-200 text-xs uppercase tracking-wider text-gray-500">
						<th class="px-6 py-4 font-medium">Empresa / RUC</th>
						<th class="px-6 py-4 font-medium">Cliente Representante</th>
						<th class="px-6 py-4 font-medium">Contacto</th>
						<th class="px-6 py-4 font-medium text-right">Acciones</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200" id="empresas-table">
					<!-- Skeleton Loader -->
					<tr class="animate-pulse">
						<td class="px-6 py-4">
							<div class="flex flex-col gap-2">
								<div class="h-4 bg-gray-200 rounded w-40"></div>
								<div class="h-3 bg-gray-200 rounded w-24"></div>
							</div>
						</td>
						<td class="px-6 py-4">
							<div class="flex items-center gap-2">
								<div class="w-6 h-6 bg-gray-200 rounded-full"></div>
								<div class="h-4 bg-gray-200 rounded w-32"></div>
							</div>
						</td>
						<td class="px-6 py-4">
							<div class="flex flex-col gap-2">
								<div class="h-3 bg-gray-200 rounded w-32"></div>
								<div class="h-3 bg-gray-200 rounded w-24"></div>
							</div>
						</td>
						<td class="px-6 py-4 text-right"><div class="h-8 w-8 bg-gray-200 rounded ml-auto"></div></td>
					</tr>
				</tbody>
			</table>
		</div>
		
		<!-- Pagination Footer -->
		<div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
			<span class="text-sm text-gray-500" id="table-info">Cargando...</span>
			<div class="flex gap-2">
				<button disabled class="px-3 py-1 bg-white border border-gray-300 text-gray-500 rounded text-sm disabled:opacity-50">Anterior</button>
				<button disabled class="px-3 py-1 bg-white border border-gray-300 text-gray-500 rounded text-sm disabled:opacity-50">Siguiente</button>
			</div>
		</div>
	</div>

	<script>
		import { supabase } from '../../../lib/supabase';

		const loadEmpresas = async () => {
			try {
				const { data: empresas, error, count } = await supabase
					.from('empresas')
					.select(`
						*,
						clientes (nombres, apellidos)
					`, { count: 'exact' })
					.order('created_at', { ascending: false });

				if (error) throw error;

				const tbody = document.getElementById('empresas-table');
				const info = document.getElementById('table-info');

				if (tbody) {
					if (!empresas || empresas.length === 0) {
						tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-12 text-center text-gray-500">
							<div class="flex flex-col items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 mb-4"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
								<p>No hay empresas registradas.</p>
							</div>
						</td></tr>`;
					} else {
						tbody.innerHTML = empresas.map((e: any) => {
							const clientName = e.clientes ? `${e.clientes.nombres} ${e.clientes.apellidos}` : 'Sin representante';
							
							return `
								<tr class="hover:bg-gray-50 transition-colors group">
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="font-medium text-gray-900">${e.razon_social}</div>
										<div class="flex items-center gap-2 mt-1">
											<span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-800 border border-gray-200">
												RUC
											</span>
											<span class="text-xs text-gray-600 font-mono">${e.numero_ruc}</span>
										</div>
										${e.nombre_comercial ? `<div class="text-xs text-gray-500 mt-1">Comercial: ${e.nombre_comercial}</div>` : ''}
									</td>
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="flex items-center gap-2">
											<div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-[10px] uppercase">
												${e.clientes ? e.clientes.nombres.charAt(0) : '?'}
											</div>
											<div class="font-medium text-gray-900 text-sm">${clientName}</div>
										</div>
									</td>
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="flex items-center gap-2 text-gray-600 mb-1">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
											<span class="text-sm">${e.telefono || '--'}</span>
										</div>
										<div class="flex items-center gap-2 text-gray-600">
											<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
											<span class="text-sm truncate w-40" title="${e.direccion || ''}">${e.direccion || '--'}</span>
										</div>
									</td>
									<td class="px-6 py-4 whitespace-nowrap text-right">
										<button class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100" title="Editar">
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
										</button>
									</td>
								</tr>
							`;
						}).join('');
					}
				}

				if (info) {
					info.innerText = `Mostrando ${empresas?.length || 0} de ${count || 0} empresas`;
				}

			} catch (error) {
				console.error('Error loading empresas:', error);
				const tbody = document.getElementById('empresas-table');
				if (tbody) {
					tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-8 text-center text-red-500">Error cargando datos. Verifique conexión a Supabase.</td></tr>`;
				}
			}
		};

		// Run
		loadEmpresas();
	</script>
</AdminLayout>
