---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---
<AdminLayout title="Nueva Empresa">
	
	<div class="mb-6 flex items-center justify-between">
		<a href="/admin/empresas" class="text-sm font-medium text-gray-500 hover:text-gray-900 flex items-center gap-2 transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
			Volver a Empresas
		</a>
	</div>

	<div class="bg-white rounded-xl border border-gray-200 shadow-sm max-w-3xl">
		<div class="px-6 py-5 border-b border-gray-200 bg-gray-50/50 rounded-t-xl">
			<h2 class="text-lg font-semibold text-gray-900">Datos de la Empresa</h2>
			<p class="text-sm text-gray-500 mt-1">Registra los datos fiscales para facturación o seguimiento comercial.</p>
		</div>
		
		<form id="nueva-empresa-form" class="p-6">
			<div id="form-alert" class="hidden mb-6 p-4 rounded-lg text-sm" role="alert"></div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
				<!-- Cliente Representante (Select) -->
				<div class="md:col-span-2">
					<label for="id_cliente" class="block mb-2 text-sm font-medium text-gray-900">Cliente Representante <span class="text-red-500">*</span></label>
					<select id="id_cliente" name="id_cliente" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" required>
						<option value="" disabled selected>Cargando clientes...</option>
					</select>
					<p class="mt-1 text-xs text-gray-500">La empresa debe estar vinculada a un cliente previamente registrado.</p>
				</div>
				
				<!-- Razón Social -->
				<div class="md:col-span-2">
					<label for="razon_social" class="block mb-2 text-sm font-medium text-gray-900">Razón Social <span class="text-red-500">*</span></label>
					<input type="text" id="razon_social" name="razon_social" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" placeholder="Ej. Agencia Creativa SAC" required>
				</div>
				
				<!-- RUC -->
				<div>
					<label for="numero_ruc" class="block mb-2 text-sm font-medium text-gray-900">Número de RUC <span class="text-red-500">*</span></label>
					<input type="text" id="numero_ruc" name="numero_ruc" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" placeholder="Ej. 20123456789" required>
				</div>
				
				<!-- Nombre Comercial -->
				<div>
					<label for="nombre_comercial" class="block mb-2 text-sm font-medium text-gray-900">Nombre Comercial</label>
					<input type="text" id="nombre_comercial" name="nombre_comercial" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" placeholder="Ej. Agencia Alpha">
				</div>

				<!-- Teléfono Empresarial -->
				<div>
					<label for="telefono" class="block mb-2 text-sm font-medium text-gray-900">Teléfono Corporativo</label>
					<input type="tel" id="telefono" name="telefono" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" placeholder="(01) 234 5678">
				</div>

				<!-- Dirección -->
				<div class="md:col-span-2">
					<label for="direccion" class="block mb-2 text-sm font-medium text-gray-900">Dirección Fiscal</label>
					<input type="text" id="direccion" name="direccion" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full p-2.5" placeholder="Av. Principal 123, Ciudad">
				</div>
			</div>

			<div class="flex items-center justify-end gap-4 pt-4 border-t border-gray-200">
				<a href="/admin/empresas" class="text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-900 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors">
					Cancelar
				</a>
				<button type="submit" id="submit-btn" class="text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin" id="submit-spinner"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
					Guardar Empresa
				</button>
			</div>
		</form>
	</div>

	<script>
		import { supabase } from '../../../lib/supabase';

		const form = document.getElementById('nueva-empresa-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
		const submitSpinner = document.getElementById('submit-spinner');
		const alertBox = document.getElementById('form-alert');
		const clienteSelect = document.getElementById('id_cliente') as HTMLSelectElement;

		const showAlert = (message: string, isError = false) => {
			if (!alertBox) return;
			alertBox.textContent = message;
			alertBox.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'bg-green-50', 'text-green-800');
			
			if (isError) {
				alertBox.classList.add('bg-red-50', 'text-red-800');
			} else {
				alertBox.classList.add('bg-green-50', 'text-green-800');
			}
		};

		// Fetch clients for dropdown
		const loadClientesForSelect = async () => {
			try {
				const { data, error } = await supabase.from('clientes').select('id_cliente, nombres, apellidos').order('nombres');
				if (error) throw error;
				
				if (clienteSelect) {
					clienteSelect.innerHTML = `<option value="" disabled selected>Selecciona un cliente</option>` + 
					(data || []).map(c => `<option value="${c.id_cliente}">${c.nombres} ${c.apellidos}</option>`).join('');
				}
			} catch (error) {
				console.error('Error fetching clients:', error);
				if (clienteSelect) {
					clienteSelect.innerHTML = `<option value="" disabled>Error al cargar clientes</option>`;
				}
			}
		};
		loadClientesForSelect();

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			// Loading state
			submitBtn.disabled = true;
			submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
			submitSpinner?.classList.remove('hidden');
			alertBox?.classList.add('hidden');

			const formData = new FormData(form);
			
			const dataForm = {
				id_cliente: formData.get('id_cliente'),
				razon_social: formData.get('razon_social'),
				numero_ruc: formData.get('numero_ruc'),
				nombre_comercial: formData.get('nombre_comercial') || null,
				direccion: formData.get('direccion') || null,
				telefono: formData.get('telefono') || null,
			};

			try {
				const { data, error } = await supabase
					.from('empresas')
					.insert([dataForm])
					.select();

				if (error) {
					// Handle duplicate document error
					if (error.code === '23505') {
						throw new Error('Ya existe una empresa registrada con ese RUC.');
					}
					throw error;
				}

				// Success
				showAlert('Empresa creada exitosamente. Redirigiendo...', false);
				form.reset();
				
				// Redirect after brief delay
				setTimeout(() => {
					window.location.href = '/admin/empresas';
				}, 1500);

			} catch (error: any) {
				console.error('Error insertando empresa:', error);
				showAlert(error.message || 'Ocurrió un error al guardar la empresa.', true);
			} finally {
				// Reset loading state if not successfully redirected
				submitBtn.disabled = false;
				submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
				submitSpinner?.classList.add('hidden');
			}
		});
	</script>
</AdminLayout>
