---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---
<AdminLayout title="Facturas">
	
	<div class="mb-6 flex flex-col sm:flex-row gap-4 items-center justify-between">
		<div class="relative w-full sm:w-80">
			<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
			</div>
			<input type="text" id="search-input" class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full pl-10 p-2.5 shadow-sm" placeholder="Buscar factura o empresa...">
		</div>
		<div class="flex gap-3 w-full sm:w-auto overflow-x-auto pb-1 sm:pb-0">
			<select class="bg-white border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block p-2.5 shadow-sm min-w-36">
				<option value="">Todos los Estados</option>
				<option value="pendiente">Pendiente</option>
				<option value="pagada">Pagada</option>
				<option value="vencida">Vencida</option>
				<option value="anulada">Anulada</option>
			</select>
			<button type="button" class="whitespace-nowrap flex-shrink-0 flex items-center justify-center gap-2 text-white bg-emerald-600 hover:bg-emerald-700 focus:ring-4 focus:ring-emerald-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
				Nueva Factura
			</button>
		</div>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6" id="invoice-stats">
		<!-- Dynamic Stats -->
	</div>

	<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
		<div class="overflow-x-auto">
			<table class="w-full text-left border-collapse">
				<thead>
					<tr class="bg-gray-50 border-b border-gray-200 text-xs uppercase tracking-wider text-gray-500">
						<th class="px-6 py-4 font-medium">Factura</th>
						<th class="px-6 py-4 font-medium">Empresa / Cliente</th>
						<th class="px-6 py-4 font-medium">Monto</th>
						<th class="px-6 py-4 font-medium">Estado</th>
						<th class="px-6 py-4 font-medium">Emisión</th>
						<th class="px-6 py-4 font-medium text-right">Acciones</th>
					</tr>
				</thead>
				<tbody class="divide-y divide-gray-200" id="facturas-table">
					<!-- Skeleton Loader -->
					<tr class="animate-pulse">
						<td class="px-6 py-4"><div class="h-4 bg-gray-200 rounded w-16"></div></td>
						<td class="px-6 py-4">
							<div class="flex flex-col gap-2">
								<div class="h-4 bg-gray-200 rounded w-32"></div>
								<div class="h-3 bg-gray-200 rounded w-24"></div>
							</div>
						</td>
						<td class="px-6 py-4"><div class="h-5 bg-gray-200 rounded w-20"></div></td>
						<td class="px-6 py-4"><div class="h-6 bg-gray-200 rounded-full w-20"></div></td>
						<td class="px-6 py-4"><div class="h-4 bg-gray-200 rounded w-24"></div></td>
						<td class="px-6 py-4 text-right"><div class="h-8 w-8 bg-gray-200 rounded ml-auto"></div></td>
					</tr>
				</tbody>
			</table>
		</div>
		
		<!-- Pagination Footer -->
		<div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex items-center justify-between">
			<span class="text-sm text-gray-500" id="table-info">Cargando...</span>
			<div class="flex gap-2">
				<button disabled class="px-3 py-1 bg-white border border-gray-300 text-gray-500 rounded text-sm disabled:opacity-50">Anterior</button>
				<button disabled class="px-3 py-1 bg-white border border-gray-300 text-gray-500 rounded text-sm disabled:opacity-50">Siguiente</button>
			</div>
		</div>
	</div>

	<script>
		import { supabase } from '../../../lib/supabase';

		const getShortId = (uuid: string) => uuid ? uuid.split('-')[0].toUpperCase() : 'N/A';

		const loadFacturas = async () => {
			try {
				const { data: facturas, error, count } = await supabase
					.from('factura')
					.select(`
						*,
						empresas (razon_social),
						tipo_servicio (nombre_servicio)
					`, { count: 'exact' })
					.order('fecha_emision', { ascending: false });

				if (error) throw error;

				const tbody = document.getElementById('facturas-table');
				const info = document.getElementById('table-info');

				// Calculate stats
				let totalAmount = 0;
				let pendingAmount = 0;
				let pendingCount = 0;

				if (facturas) {
					facturas.forEach(f => {
						const amount = Number(f.monto_total) || 0;
						if (f.estado === 'pagada') totalAmount += amount;
						if (f.estado === 'pendiente') {
							pendingAmount += amount;
							pendingCount++;
						}
					});
				}

				// Render stats
				const statsContainer = document.getElementById('invoice-stats');
				if (statsContainer) {
					statsContainer.innerHTML = `
						<div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
							<p class="text-sm font-medium text-gray-500 mb-1">Total Ingresado</p>
							<h3 class="text-2xl font-bold text-gray-900">$${totalAmount.toLocaleString()}</h3>
						</div>
						<div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm border-l-4 border-l-orange-500">
							<p class="text-sm font-medium text-gray-500 mb-1">Pendiente de Cobro</p>
							<h3 class="text-2xl font-bold text-gray-900">$${pendingAmount.toLocaleString()}</h3>
						</div>
						<div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
							<p class="text-sm font-medium text-gray-500 mb-1">Facturas Pendientes</p>
							<h3 class="text-2xl font-bold text-gray-900">${pendingCount}</h3>
						</div>
						<div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
							<p class="text-sm font-medium text-gray-500 mb-1">Total Emitidas</p>
							<h3 class="text-2xl font-bold text-gray-900">${count || 0}</h3>
						</div>
					`;
				}

				if (tbody) {
					if (!facturas || facturas.length === 0) {
						tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-12 text-center text-gray-500">
							<div class="flex flex-col items-center justify-center">
								<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 mb-4"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><path d="M14 8H8"/><path d="M16 12H8"/><path d="M13 16H8"/></svg>
								<p>No hay facturas registradas.</p>
							</div>
						</td></tr>`;
					} else {
						tbody.innerHTML = facturas.map((f: any) => {
							const idStr = `FAC-${getShortId(f.id_factura)}`;
							const companyName = f.empresas?.razon_social || 'Desconocida';
							const serviceName = f.tipo_servicio?.nombre_servicio || 'Servicio General';
							const amount = f.monto_total ? Number(f.monto_total).toLocaleString('es-ES', { minimumFractionDigits: 2 }) : '0.00';
							const date = f.fecha_emision ? new Date(f.fecha_emision).toLocaleDateString('es-ES') : '--';
							
							// Badge color based on state
							let badgeColor = 'bg-gray-100 text-gray-800';
							if (f.estado === 'pendiente') badgeColor = 'bg-orange-100 text-orange-800 border-orange-200';
							else if (f.estado === 'pagada') badgeColor = 'bg-emerald-100 text-emerald-800 border-emerald-200';
							else if (f.estado === 'vencida') badgeColor = 'bg-red-100 text-red-800 border-red-200';
							else if (f.estado === 'anulada') badgeColor = 'bg-gray-200 text-gray-500 border-gray-300';

							return `
								<tr class="hover:bg-gray-50 transition-colors group">
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="font-medium text-gray-900">${idStr}</div>
									</td>
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="font-medium text-gray-900 text-sm">${companyName}</div>
										<div class="text-xs text-gray-500 truncate w-48" title="${serviceName}">${serviceName}</div>
									</td>
									<td class="px-6 py-4 whitespace-nowrap">
										<div class="font-semibold text-gray-900">$${amount}</div>
									</td>
									<td class="px-6 py-4 whitespace-nowrap">
										<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${badgeColor} capitalize">
											${f.estado || 'pendiente'}
										</span>
									</td>
									<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
										${date}
									</td>
									<td class="px-6 py-4 whitespace-nowrap text-right">
										<button class="p-2 text-gray-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100" title="Ver Factura">
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
										</button>
										<button class="p-2 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100 ml-1" title="Descargar PDF">
											<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
										</button>
									</td>
								</tr>
							`;
						}).join('');
					}
				}

				if (info) {
					info.innerText = `Mostrando ${facturas?.length || 0} de ${count || 0} facturas`;
				}

			} catch (error) {
				console.error('Error loading facturas:', error);
				const tbody = document.getElementById('facturas-table');
				if (tbody) {
					tbody.innerHTML = `<tr><td colspan="6" class="px-6 py-8 text-center text-red-500">Error cargando datos. Verifique conexión a Supabase.</td></tr>`;
				}
			}
		};

		// Run
		loadFacturas();
	</script>
</AdminLayout>
