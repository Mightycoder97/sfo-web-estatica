---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---
<AdminLayout title="Nuevo Servicio">
	
	<div class="mb-6 flex items-center justify-between">
		<a href="/admin/servicios" class="text-sm font-medium text-gray-500 hover:text-gray-900 flex items-center gap-2 transition-colors">
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
			Volver a Servicios
		</a>
	</div>

	<div class="bg-white rounded-xl border border-gray-200 shadow-sm max-w-3xl">
		<div class="px-6 py-5 border-b border-gray-200 bg-gray-50/50 rounded-t-xl">
			<h2 class="text-lg font-semibold text-gray-900">Detalles del Servicio</h2>
			<p class="text-sm text-gray-500 mt-1">Añade un nuevo tipo de servicio a tu catálogo para ofrecer a los clientes.</p>
		</div>
		
		<form id="nuevo-servicio-form" class="p-6">
			<div id="form-alert" class="hidden mb-6 p-4 rounded-lg text-sm" role="alert"></div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
				<!-- Nombre del Servicio -->
				<div class="md:col-span-2">
					<label for="nombre" class="block mb-2 text-sm font-medium text-gray-900">Nombre del Servicio <span class="text-red-500">*</span></label>
					<input type="text" id="nombre" name="nombre" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-purple-500 focus:border-purple-500 block w-full p-2.5" placeholder="Ej. Desarrollo Web Corporativo" required>
				</div>
				
				<!-- Precio Base -->
				<div>
					<label for="precio_base" class="block mb-2 text-sm font-medium text-gray-900">Precio Base (USD) <span class="text-red-500">*</span></label>
					<div class="relative">
						<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
							<span class="text-gray-500 sm:text-sm">$</span>
						</div>
						<input type="number" step="0.01" min="0" id="precio_base" name="precio_base" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-purple-500 focus:border-purple-500 block w-full pl-8 p-2.5" placeholder="0.00" required>
					</div>
				</div>

				<!-- Descripción -->
				<div class="md:col-span-2">
					<label for="descripcion" class="block mb-2 text-sm font-medium text-gray-900">Descripción Corta</label>
					<textarea id="descripcion" name="descripcion" rows="4" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-purple-500 focus:border-purple-500 block w-full p-2.5" placeholder="Describe brevemente en qué consiste este servicio..."></textarea>
				</div>
			</div>

			<div class="flex items-center justify-end gap-4 pt-4 border-t border-gray-200">
				<a href="/admin/servicios" class="text-gray-500 bg-white border border-gray-300 hover:bg-gray-100 hover:text-gray-900 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors">
					Cancelar
				</a>
				<button type="submit" id="submit-btn" class="text-white bg-purple-600 hover:bg-purple-700 focus:ring-4 focus:ring-purple-300 font-medium rounded-lg text-sm px-5 py-2.5 focus:outline-none transition-colors flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin" id="submit-spinner"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
					Guardar Servicio
				</button>
			</div>
		</form>
	</div>

	<script>
		import { supabase } from '../../../lib/supabase';

		const form = document.getElementById('nuevo-servicio-form') as HTMLFormElement;
		const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
		const submitSpinner = document.getElementById('submit-spinner');
		const alertBox = document.getElementById('form-alert');

		const showAlert = (message: string, isError = false) => {
			if (!alertBox) return;
			alertBox.textContent = message;
			alertBox.classList.remove('hidden', 'bg-red-50', 'text-red-800', 'bg-green-50', 'text-green-800');
			
			if (isError) {
				alertBox.classList.add('bg-red-50', 'text-red-800');
			} else {
				alertBox.classList.add('bg-green-50', 'text-green-800');
			}
		};

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			// Loading state
			submitBtn.disabled = true;
			submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
			submitSpinner?.classList.remove('hidden');
			alertBox?.classList.add('hidden');

			const formData = new FormData(form);
			
			const dataForm = {
				nombre: formData.get('nombre'),
				precio_base: parseFloat(formData.get('precio_base') as string) || 0,
				descripcion: formData.get('descripcion') || null,
			};

			try {
				const { data, error } = await supabase
					.from('tipo_servicio_catalogo')
					.insert([dataForm])
					.select();

				if (error) throw error;

				// Success
				showAlert('Servicio añadido exitosamente. Redirigiendo...', false);
				form.reset();
				
				// Redirect after brief delay
				setTimeout(() => {
					window.location.href = '/admin/servicios';
				}, 1500);

			} catch (error: any) {
				console.error('Error insertando servicio:', error);
				showAlert(error.message || 'Ocurrió un error al guardar el servicio.', true);
			} finally {
				// Reset loading state if not successfully redirected
				submitBtn.disabled = false;
				submitBtn.classList.remove('opacity-75', 'cursor-not-allowed');
				submitSpinner?.classList.add('hidden');
			}
		});
	</script>
</AdminLayout>
