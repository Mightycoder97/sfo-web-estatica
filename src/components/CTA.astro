---
---

<section id="contacto" class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-primary-900"></div>
    <div
        class="absolute inset-0 opacity-10"
        style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 32px 32px;"
    >
    </div>

    <div
        class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[600px] h-[600px] rounded-full bg-primary-600/30 blur-3xl pointer-events-none"
        aria-hidden="true"
    >
    </div>
    <div
        class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[600px] h-[600px] rounded-full bg-primary-800/50 blur-3xl pointer-events-none"
        aria-hidden="true"
    >
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div
            class="inline-flex items-center px-4 py-2 rounded-full bg-white/10 border border-white/20 text-primary-100 text-sm font-medium mb-8 backdrop-blur-sm"
        >
            <span
                class="flex h-2 w-2 rounded-full bg-green-400 mr-2 animate-pulse"
            ></span>
            Agencia Abierta a Nuevos Proyectos
        </div>

        <h2
            class="text-3xl md:text-5xl font-heading font-extrabold text-white leading-tight mb-6"
        >
            El primer paso para <br class="hidden md:block" />
            <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-primary-200 to-white"
                >escalar tu negocio hoy.</span
            >
        </h2>

        <p
            class="text-lg md:text-xl text-primary-100 mb-12 max-w-2xl mx-auto leading-relaxed"
        >
            Déjanos tus datos para agendar una breve llamada exploratoria.
            Escucharemos tu visión y te propondremos la ruta tecnológica exacta
            para hacerla realidad, sin compromisos.
        </p>

        <form
            id="contact-form"
            class="glass-dark p-6 sm:p-8 md:p-10 rounded-3xl max-w-3xl mx-auto text-left relative overflow-hidden group"
        >
            <div
                class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"
            >
            </div>

            <div class="relative z-10 grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-medium text-gray-300 mb-2"
                        >Nombre completo</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
                        placeholder="Ej. Juan Pérez"
                        required
                    />
                </div>
                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-gray-300 mb-2"
                        >Correo corporativo / Email</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
                        placeholder="tu@empresa.com"
                        required
                    />
                </div>
                <div class="sm:col-span-2">
                    <label
                        for="phone"
                        class="block text-sm font-medium text-gray-300 mb-2"
                        >Número de Teléfono</label
                    >
                    <input
                        type="tel"
                        id="phone"
                        name="phone"
                        class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all"
                        placeholder="Ej. +51 987 654 321"
                        required
                    />
                </div>
                <div class="sm:col-span-2">
                    <label
                        for="message"
                        class="block text-sm font-medium text-gray-300 mb-2"
                        >Cuéntanos sobre tus metas comerciales</label
                    >
                    <textarea
                        id="message"
                        name="message"
                        rows="4"
                        class="w-full px-4 py-3 bg-gray-800/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all resize-none"
                        placeholder="¿Qué esperas lograr en los próximos 6 meses con este proyecto?..."
                        required></textarea>
                </div>

                <div
                    class="sm:col-span-2 flex flex-col sm:flex-row items-center justify-between mt-4 gap-4 sm:gap-0"
                >
                    <p
                        class="text-xs text-gray-400 max-w-sm text-center sm:text-left"
                    >
                        Recibirás una respuesta de nuestro equipo en menos de 2
                        horas laborables.
                    </p>
                    <button
                        type="submit"
                        class="w-full sm:w-auto inline-flex justify-center items-center px-8 md:px-10 py-3 md:py-4 border border-transparent text-base font-semibold rounded-full text-primary-900 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-900 focus:ring-white transform hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-xl"
                    >
                        Agendar Asesoría Gratuita
                        <svg
                            class="ml-2 -mr-1 w-5 h-5 flex-shrink-0"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const form = document.getElementById(
            "contact-form"
        ) as HTMLFormElement | null;

        if (form) {
            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                // Change button text to indicate loading
                const submitBtn = form.querySelector(
                    'button[type="submit"]'
                ) as HTMLButtonElement | null;
                let originalBtnText = "Agendar Asesoría Gratuita";

                if (submitBtn) {
                    originalBtnText = submitBtn.innerHTML;
                    submitBtn.innerHTML = "Enviando...";
                    submitBtn.disabled = true;
                }

                const formData = new FormData(form);
                const name = formData.get("name");
                const email = formData.get("email");
                const phone = formData.get("phone");
                const message = formData.get("message");

                try {
                    // Send email via FormSubmit AJAX
                    await fetch(
                        "https://formsubmit.co/ajax/contacto@sfoestudioweb.com",
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                Accept: "application/json",
                            },
                            body: JSON.stringify({
                                Nombre: name,
                                email: email, // Necesario para enviar auto-respuesta vía FormSubmit
                                Telefono: phone,
                                Metas_Comerciales: message,
                                _subject: "Nuevo Lead - Asesoría Gratuita",
                                _template: "table",
                                _autoresponse:
                                    "¡Hola! Hemos recibido tu información exitosamente. Pronto nos pondremos en contacto contigo para agendar tu asesoría gratuita. Atentamente, el equipo de SFO Estudio Web.",
                            }),
                        }
                    );

                    // Redirect to WhatsApp
                    const whatsappNumber = "51949063359";
                    const whatsappText = `Hola, mi nombre es ${name}. Acabo de solicitar una asesoría gratuita a través de la página web. Mi correo es ${email} y mi número de contacto es ${phone}.`;
                    const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(
                        whatsappText
                    )}`;

                    window.location.href = whatsappUrl;
                } catch (error) {
                    console.error("Error al enviar el formulario:", error);
                    alert(
                        "Hubo un error al enviar el formulario. Por favor, intenta contactarnos directamente por WhatsApp."
                    );
                    if (submitBtn) {
                        submitBtn.innerHTML = originalBtnText;
                        submitBtn.disabled = false;
                    }
                }
            });
        }
    });
</script>
