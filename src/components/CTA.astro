---
---

<section id="contacto" class="py-24 relative overflow-hidden bg-gray-900 text-center">
    <!-- Fondos dinámicos impactantes premium -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-gray-800 via-gray-900 to-black pointer-events-none"></div>
    <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
    >
    </div>

    <!-- Círculos de iluminación -->
    <div class="absolute top-0 right-1/4 -translate-y-12 w-[800px] h-[800px] rounded-full bg-primary-600/20 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-1/4 translate-y-1/3 w-[600px] h-[600px] rounded-full bg-fuchsia-600/20 blur-[120px] pointer-events-none"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="cta-stagger inline-flex items-center px-4 py-2 rounded-full bg-white/5 border border-white/10 text-primary-200 text-sm font-semibold mb-8 backdrop-blur-md shadow-2xl">
            <span class="flex h-2.5 w-2.5 rounded-full bg-green-400 mr-2 animate-pulse shadow-[0_0_10px_rgba(74,222,128,0.5)]"></span>
            Agenda Disponible para Este Mes
        </div>

        <h2 class="cta-stagger text-4xl md:text-6xl font-heading font-black text-white leading-[1.1] mb-6">
            El primer paso para <br class="hidden md:block" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-400 to-fuchsia-400 drop-shadow-sm">escalar tu negocio hoy.</span>
        </h2>

        <p class="cta-stagger text-lg md:text-xl text-gray-300 mb-12 max-w-2xl mx-auto leading-relaxed font-light">
            Déjame tus datos para agendar una breve llamada. Escucharé tu visión y prepararemos una estrategia digital exacta, directo al grano.
        </p>

        <!-- Formulario -->
        <form
            id="contact-form"
            class="cta-stagger glass-dark p-8 md:p-12 rounded-[2.5rem] max-w-3xl mx-auto text-left relative overflow-hidden group shadow-2xl border border-white/10"
        >
            <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>

            <div class="relative z-10 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-8">
                <div>
                    <label for="name" class="block text-sm font-semibold text-gray-300 mb-2">Nombre completo</label>
                    <input
                        type="text"
                        id="name"
                        name="name"
                        class="w-full px-5 py-4 bg-gray-900/60 border border-gray-700/50 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition-all font-light"
                        placeholder="Ej. Juan Pérez"
                        required
                    />
                </div>
                <div>
                    <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">Email corporativo / principal</label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        class="w-full px-5 py-4 bg-gray-900/60 border border-gray-700/50 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition-all font-light"
                        placeholder="tu@empresa.com"
                        required
                    />
                </div>
                <div class="sm:col-span-2">
                    <label for="phone" class="block text-sm font-semibold text-gray-300 mb-2">Número de WhatsApp (con código de país)</label>
                    <input
                        type="tel"
                        id="phone"
                        name="phone"
                        class="w-full px-5 py-4 bg-gray-900/60 border border-gray-700/50 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition-all font-light"
                        placeholder="Ej. +51 987 654 321"
                        required
                    />
                </div>
                <div class="sm:col-span-2">
                    <label for="message" class="block text-sm font-semibold text-gray-300 mb-2">Cuéntame sobre tu proyecto</label>
                    <textarea
                        id="message"
                        name="message"
                        rows="4"
                        class="w-full px-5 py-4 bg-gray-900/60 border border-gray-700/50 rounded-2xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500/50 focus:border-primary-500 transition-all resize-none font-light"
                        placeholder="¿Qué esperas lograr con este proyecto? ¿Tienes alguna referencia en mente?"
                        required></textarea>
                </div>

                <div class="sm:col-span-2 flex flex-col sm:flex-row items-center justify-between mt-4 gap-6">
                    <p class="text-xs text-gray-400 max-w-sm text-center sm:text-left leading-relaxed">
                        Recibirás un <strong class="text-white">correo de bienvenida instantáneo</strong> y nos pondremos en contacto súper rápido.
                    </p>
                    <button
                        type="submit"
                        class="w-full sm:w-auto inline-flex justify-center items-center px-10 py-5 font-bold rounded-2xl text-white bg-gradient-to-r from-primary-600 to-fuchsia-600 hover:from-primary-500 hover:to-fuchsia-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-900 focus:ring-primary-500 transform hover:-translate-y-1 transition-all duration-300 shadow-[0_10px_20px_rgba(99,102,241,0.2)]"
                    >
                        <span>Solicitar Contacto</span>
                        <svg class="ml-2 w-5 h-5 flex-shrink-0 relative top-[1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<!-- GSAP Script -->
<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        // Setup GSAP
        if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
            gsap.registerPlugin(ScrollTrigger);

            gsap.set(".cta-stagger", { y: 40, opacity: 0 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: "#contacto",
                    start: "top 85%",
                }
            });

            tl.to(".cta-stagger", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.15,
                ease: "power3.out"
            });
        }

        const form = document.getElementById("contact-form");

        if (form) {
            form.addEventListener("submit", async function (e) {
                e.preventDefault();

                const submitBtn = form.querySelector('button[type="submit"]');
                let originalBtnText = "";
                let originalBtnChild;

                if (submitBtn) {
                     originalBtnChild = submitBtn.querySelector('span');
                     if(originalBtnChild) {
                         originalBtnText = originalBtnChild.innerHTML;
                         originalBtnChild.innerHTML = "Procesando...";
                     }
                    submitBtn.disabled = true;
                    submitBtn.classList.add('opacity-70');
                }

                const formData = new FormData(form);
                const name = formData.get("name");
                const email = formData.get("email");
                const phone = formData.get("phone");
                const message = formData.get("message");

                try {
                    // Send email via FormSubmit AJAX - Envía a contacto@sfoestudioweb.com (Tal y como solicitaste)
                    await fetch(
                        "https://formsubmit.co/ajax/contacto@sfoestudioweb.com",
                        {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                Accept: "application/json",
                            },
                            body: JSON.stringify({
                                Nombre: name,
                                Email_Cliente: email,
                                email: email, // Necesario para AutoResponse
                                Telefono: phone,
                                Mensaje: message,
                                _subject: "Nuevo Proyecto Web - SFO Estudio Web",
                                _template: "table",
                                _autoresponse: "¡Hola! He recibido tu mensaje correctamente. Estoy revisando tu solicitud y me pondré en contacto contigo lo antes posible para ayudarte a escalar tu proyecto. - Sebastián de SFO Estudio Web",
                            }),
                        }
                    );

                    // Redirección a WhatsApp directa (Notificación + Conversación rápida)
                    const whatsappNumber = "51949063359";
                    const whatsappText = `Hola Sebastián de SFO Estudio Web, mi nombre es ${name}. He llenado el formulario web para mi proyecto. Mi correo es ${email} y mi número es ${phone}.`;
                    const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(
                        whatsappText
                    )}`;

                    window.location.href = whatsappUrl;
                } catch (error) {
                    console.error("Error al enviar el formulario:", error);
                    alert("Ocurrió un error al enviar el formulario. Por favor contáctame directo al WhatsApp: +51 949 063 359.");
                    if (submitBtn && originalBtnChild) {
                        originalBtnChild.innerHTML = originalBtnText;
                        submitBtn.disabled = false;
                        submitBtn.classList.remove('opacity-70');
                    }
                }
            });
        }
    });
</script>
