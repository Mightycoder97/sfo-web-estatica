---
const services = [
    {
        title: "Tu Primera Página Web",
        description:
            "Diseño llave en mano para emprendedores. Despega tu marca personal o negocio con una Landing Page optimizada para captar clientes desde el día 1.",
        image: "https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        tags: ["Landing Page", "Conversión", "Leads"],
    },
    {
        title: "Rediseño Web Moderno",
        description:
            "¿Tu web actual se ve anticuada o no carga rápido? Modernizo por completo tu sitio aplicando las mejores prácticas de UX/UI para multiplicar tus ventas.",
        image: "https://images.unsplash.com/photo-1542744173-8e7e53415bb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        tags: ["UX / UI", "Optimización", "Performance"],
    },
    {
        title: "Tiendas Virtuales (E-Commerce)",
        description:
            "Vende 24/7 sin barreras. Catálogos autogestionables, pasarelas de pago automatizadas e integraciones para que tu tienda sea una máquina de ventas.",
        image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        tags: ["E-Commerce", "Ventas", "Pasaportes de Pago"],
    },
    {
        title: "Sistemas Web para Empresas",
        description:
            "Desarrollo de software a medida. Construyo portales, CRMs, Intranets y plataformas robustas que escalen junto con el crecimiento de tu operación.",
        image: "https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        tags: ["React", "Bases de Datos", "SaaS"],
    },
];
---

<section id="servicios" class="py-24 bg-gray-50 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-8 text-center md:text-left services-stagger">
            <div class="max-w-2xl mx-auto md:mx-0">
                <h2 class="text-primary-600 font-bold tracking-wider uppercase text-sm mb-3">
                    Mis Servicios Profesionales
                </h2>
                <p class="text-3xl md:text-5xl leading-tight font-heading font-black tracking-tight text-gray-900">
                    Construyo el motor <span class="text-gradient">de tus ventas futuras</span>.
                </p>
                <p class="mt-4 text-lg text-gray-600 font-light max-w-xl mx-auto md:mx-0">
                    Elije la ruta tecnológica exacta para impulsar tu negocio al siguiente nivel.
                </p>
            </div>
            <div class="flex-shrink-0">
                <a href="#contacto" class="inline-flex items-center text-primary-600 font-bold hover:text-primary-700 transition-colors bg-primary-50 px-6 py-3 rounded-full hover:bg-primary-100">
                    ¿Cuál necesitas? Hablemos
                    <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
            {
                services.map((service) => (
                    <div class="service-card flex flex-col sm:flex-row bg-white rounded-3xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-2xl hover:border-primary-200 transition-all duration-300 group hover:-translate-y-1">
                        
                        <div class="relative overflow-hidden sm:w-2/5 h-64 sm:h-auto">
                            <div class="absolute inset-0 bg-primary-900/10 group-hover:bg-transparent transition-colors z-10 duration-500"></div>
                            <img
                                src={service.image}
                                alt={service.title}
                                class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700 ease-in-out"
                                loading="lazy"
                            />
                        </div>

                        <div class="p-8 sm:w-3/5 flex flex-col">
                            <div class="flex flex-wrap gap-2 mb-4">
                                {service.tags.map((tag) => (
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-gray-100 text-gray-600 group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            
                            <h3 class="text-2xl font-heading font-black text-gray-900 mb-3 group-hover:text-fuchsia-600 transition-colors leading-tight">
                                {service.title}
                            </h3>
                            
                            <p class="text-gray-600 text-sm md:text-base mb-6 flex-grow leading-relaxed font-light">
                                {service.description}
                            </p>
                            
                            <a
                                href="#contacto"
                                class="inline-flex items-center font-bold text-gray-900 group-hover/link mt-auto bg-gray-50 border border-gray-200 px-4 py-2 rounded-xl w-max hover:bg-gray-100 transition-colors text-sm"
                            >
                                Solicitar Cotización
                                <svg
                                    class="ml-2 w-4 h-4 transform group-hover/link:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<!-- GSAP Animation Script -->
<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
            gsap.registerPlugin(ScrollTrigger);
            
            // Set init state
            gsap.set(".services-stagger", { y: 30, opacity: 0 });
            gsap.set(".service-card", { y: 40, opacity: 0 });

            const tl = gsap.timeline({
                scrollTrigger: {
                    trigger: "#servicios",
                    start: "top 85%",
                }
            });

            tl.to(".services-stagger", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                ease: "power3.out"
            });

            tl.to(".service-card", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.1,
                ease: "power2.out"
            }, "-=0.4");
        }
    });
</script>
