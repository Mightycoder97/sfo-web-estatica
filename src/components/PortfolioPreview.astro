---
const projects = [
	{
		title: "La Bohemia | Restaurante & Eventos",
		thumbnail: "/img/portafolio/restaurante.png",
		tags: ["Gastronomía", "Inmersivo"],
        url: "https://restaurante-eventos.vercel.app/"
	},
	{
		title: "Dharsain Inmobiliaria",
		thumbnail: "/img/portafolio/inmobiliaria.png",
		tags: ["Corporativo", "Ventas"],
        url: "https://desarrolladora-inmobiliaria.vercel.app/"
	},
	{
		title: "H&H Metalmecánica",
		thumbnail: "/img/portafolio/metalmecanica.png",
		tags: ["Industrial", "B2B"],
        url: "https://hh-metalmecanica.vercel.app/"
	},
    {
		title: "IO Group | Gestión de Residuos",
		thumbnail: "/img/portafolio/io_group.png",
		tags: ["Ambiental", "Corporativo"],
        url: "https://portafolio-aplicacion-web.vercel.app/"
	},
    {
		title: "Gasfitero en Juliaca 24/7",
		thumbnail: "/img/portafolio/gasfitero.png",
		tags: ["Landing Page", "Conversión"],
        url: "https://gasfitero-en-juliaca.vercel.app/"
	}
];
---

<section id="portafolio" class="py-24 bg-gray-900 overflow-hidden relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center md:text-left mb-16 max-w-2xl mx-auto md:mx-0 portfolio-stagger">
            <span class="text-primary-400 font-bold tracking-wider uppercase text-sm mb-3 block">
                Trabajos Destacados
            </span>
            <h2 class="text-3xl md:text-5xl font-heading font-black text-white mb-6 leading-tight">
                Mi Portafolio de <br class="hidden lg:block"/> Proyectos Reales
            </h2>
            <p class="text-lg text-gray-400 font-light">
                Diseños premium enfocados en cautivar a los usuarios y multiplicar conversiones. Explora mis últimos desarrollos en Producción.
            </p>
        </div>

        <!-- Grid de Proyectos estilo Masonry / Irregular -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {projects.map((project, index) => (
                <a 
                    href={project.url} 
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`portfolio-card group block relative rounded-3xl overflow-hidden bg-gray-800 border-2 border-gray-700/50 hover:border-primary-500 transition-all duration-500 hover:-translate-y-2 shadow-lg 
                    ${index === 0 ? 'md:col-span-2 lg:col-span-2' : ''} 
                    ${index === 1 || index === 2 ? 'lg:col-span-1' : ''}
                    ${index === 3 || index === 4 ? 'md:col-span-1 lg:col-span-1' : ''}
                    `}
                >
                    <div class={`relative ${index === 0 ? 'h-[25rem] md:h-[30rem]' : 'h-80 md:h-96'} overflow-hidden`}>
                        <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-gray-900/40 to-transparent z-10"></div>
                        <img 
                            src={project.thumbnail} 
                            alt={project.title} 
                            class="absolute inset-0 w-full h-full object-cover object-top filter brightness-90 group-hover:scale-105 transition-transform duration-700 ease-out"
                            loading="lazy"
                        />
                        
                        <!-- Hover Action Indicator -->
                        <div class="absolute top-6 right-6 z-20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 transform translate-x-4 group-hover:translate-x-0">
                            <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center border border-white/30 text-white">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                            </div>
                        </div>

                        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 z-20">
                            <div class="flex flex-wrap gap-2 mb-3">
                                {project.tags.map(tag => (
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold bg-white/10 text-gray-200 backdrop-blur-md border border-white/10 uppercase tracking-wide">
                                        {tag}
                                    </span>
                                ))}
                            </div>
                            <h3 class="text-xl md:text-3xl font-bold text-white group-hover:text-primary-400 transition-colors leading-tight">
                                {project.title}
                            </h3>
                        </div>
                    </div>
                </a>
            ))}
        </div>
    </div>
</section>

<!-- GSAP Animation Script -->
<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        if (typeof gsap !== "undefined" && typeof ScrollTrigger !== "undefined") {
            gsap.registerPlugin(ScrollTrigger);

            gsap.set(".portfolio-stagger", { y: 30, opacity: 0 });
            gsap.set(".portfolio-card", { y: 50, opacity: 0 });

            const tl2 = gsap.timeline({
                scrollTrigger: {
                    trigger: "#portafolio",
                    start: "top 85%",
                }
            });

            tl2.to(".portfolio-stagger", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                ease: "power3.out"
            });

            tl2.to(".portfolio-card", {
                y: 0,
                opacity: 1,
                duration: 0.8,
                stagger: 0.15,
                ease: "power3.out"
            }, "-=0.4");
        }
    });
</script>
